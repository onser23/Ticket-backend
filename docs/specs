## 8. File Upload

### Backend Konfiqurasiya

```js
// middleware/upload.js
const multer = require('multer');
const path = require('path');
const fs = require('fs');
const crypto = require('crypto');

const UPLOADS_DIR = path.join(__dirname, '../uploads/tickets');
if (!fs.existsSync(UPLOADS_DIR)) fs.mkdirSync(UPLOADS_DIR, { recursive: true });

const storage = multer.diskStorage({
  destination: (req, file, cb) => cb(null, UPLOADS_DIR),
  filename: (req, file, cb) => {
    const uuid = crypto.randomUUID();
    const ext = path.extname(file.originalname).toLowerCase();
    cb(null, `${uuid}${ext}`);
  }
});

const ALLOWED_MIMES = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp', 'image/gif'];
const ALLOWED_EXTS = ['.jpg', '.jpeg', '.png', '.webp', '.gif'];

const fileFilter = (req, file, cb) => {
  const ext = path.extname(file.originalname).toLowerCase();
  if (ALLOWED_MIMES.includes(file.mimetype) && ALLOWED_EXTS.includes(ext)) {
    cb(null, true);
  } else {
    cb(new Error('Yalnız şəkil faylları (jpg, jpeg, png, webp, gif) qəbul olunur'), false);
  }
};

const upload = multer({
  storage,
  fileFilter,
  limits: {
    fileSize: 2 * 1024 * 1024,  // 2 MB per file
    files: 5                     // max 5 files per ticket
  }
});

module.exports = upload;
```

### Static Serving

```js
// server.js (SP3-də əlavə olunacaq)
app.use('/uploads/tickets', express.static('uploads/tickets', {
  setHeaders: (res, path) => {
    res.setHeader('Cache-Control', 'public, max-age=86400');
  }
}));
```

**Production hardening (SP7):** UUID filename artıq secure-dir (unpredictable). Əlavə auth-protected `/api/uploads/:filename` endpoint yaradıla bilər, amma MVP-də açıq serving kifayətdir.

